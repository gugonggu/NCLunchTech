# 통합 테스트(npm run test:integration)와 E2E(npm run test:e2e) 전용 값입니다.
# 개발용(.env.local)과 반드시 다른 별도 Supabase 프로젝트를 사용하세요.
# 실행 시점에 개발용 프로젝트와 같은 값이 감지되면 즉시 실패합니다.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 마이그레이션 적용용 (Session pooler 연결 문자열)
SUPABASE_DB_URL=

# 안전장치: 아래 두 값을 모두 정확히 채워야 통합/E2E 테스트가 실행됩니다.
# TEST_PROJECT_REF는 위 NEXT_PUBLIC_SUPABASE_URL의 프로젝트 ref와 반드시 일치해야 합니다.
TEST_PROJECT_REF=
ALLOW_TEST_DB_WRITES=
